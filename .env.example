# Canonical URL for sitemap, robots, and Open Graph (set the same in Vercel → Settings → Environment Variables).
NEXT_PUBLIC_SITE_URL=https://vela-website-lilac.vercel.app

# Optional — public support inbox when ready (must match App Store / Play if listed).
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Supabase configuration for survey feature
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Waitlist optional field (run once in Supabase SQL): alter table public.survey_responses add column if not exists airline text;

# MailerLite — email list for waitlist subscribers (server-side only, never NEXT_PUBLIC_).
# Find your API key in MailerLite → Integrations → API → Developer API.
# Find the Group ID in MailerLite → Subscribers → Groups → click the group → copy the ID from the URL.
MAILERLITE_API_KEY=your-mailerlite-api-key-here
MAILERLITE_GROUP_ID=your-mailerlite-group-id-here

# Optional — enable/disable survey feature in production
# SURVEY_LIVE=true

# Reference only (changes per deployment; do not use as NEXT_PUBLIC_SITE_URL):
# Deployment URL example: https://vela-website-7xc4227i3-growthwise68s-projects.vercel.app
