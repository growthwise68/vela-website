# Canonical URL for sitemap, robots, and Open Graph (set the same in Vercel → Settings → Environment Variables).
NEXT_PUBLIC_SITE_URL=https://vela-website-lilac.vercel.app

# Optional — public support inbox when ready (must match App Store / Play if listed).
# NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Supabase configuration for the survey + waitlist feature.
# IMPORTANT: the website uses its OWN dedicated Supabase project (e.g. "vela-website"),
# separate from the product/app Supabase project. Do NOT point this at the app project —
# the website writes anonymous survey data via a public key and must stay isolated.
# Schema lives in supabase/migrations/0001_survey_responses.sql (run it in the new project's SQL editor).
NEXT_PUBLIC_SUPABASE_URL=https://your-website-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# Optional — enable/disable survey feature in production
# SURVEY_LIVE=true

# Reference only (changes per deployment; do not use as NEXT_PUBLIC_SITE_URL):
# Deployment URL example: https://vela-website-7xc4227i3-growthwise68s-projects.vercel.app
